---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";

const benefits = [
	"Sterke en stabiele WiFi-dekking buiten",
	"Naadloze overgang tussen binnen- en buitennetwerk",
	"Weerbestendige professionele installatie",
	"Netjes geïntegreerd onder de overkapping",
	"Centrale configuratie via TP-Link Omada",
	"Klaar voor uitbreiding van het netwerk",
];

const technologies = [
	{
		name: "TP-Link Omada",
		description:
			"Professioneel netwerkplatform voor centrale configuratie en beheer.",
	},
	{
		name: "Outdoor access point",
		description:
			"Weerbestendig access point voor een stabiele draadloze verbinding buiten.",
	},
	{
		name: "PoE-aansluiting",
		description:
			"Voeding en netwerkverbinding via één kabel voor een nette installatie.",
	},
];
---

<Layout
	title="Outdoor WiFi-installatie | VeYo Smart Solutions"
	description="Professionele plaatsing en configuratie van een TP-Link Omada outdoor access point voor stabiele WiFi-dekking op terras, in de tuin en rond de woning."
>
	<Header />

	<main class="overflow-hidden bg-[#090909] text-white">

		<!-- HERO -->
		<section class="relative overflow-hidden pt-32">
			<div
				class="absolute inset-0 bg-[radial-gradient(circle_at_75%_20%,rgba(212,175,55,0.18),transparent_36%)]"
			></div>

			<div class="relative mx-auto max-w-7xl px-6 pb-16 lg:px-8">
				<a
					href="/#projecten"
					class="inline-flex items-center gap-2 text-sm font-bold text-neutral-400 transition hover:text-[#d4af37]"
				>
					<span aria-hidden="true">←</span>
					Terug naar projecten
				</a>

				<p
					class="mt-12 text-sm font-bold uppercase tracking-[0.25em] text-[#d4af37]"
				>
					WiFi & netwerken
				</p>

				<h1
					class="mt-5 max-w-5xl text-5xl font-black leading-[0.94] tracking-[-0.055em] sm:text-6xl lg:text-8xl"
				>
					Sterke WiFi.
					<span class="text-[#d4af37]">Ook buiten.</span>
				</h1>

				<p class="mt-8 max-w-3xl text-lg leading-8 text-neutral-300 sm:text-xl">
					Professionele plaatsing van een weerbestendig TP-Link Omada access
					point voor een stabiele draadloze verbinding op het terras, in de
					tuin en rondom de woning.
				</p>

				<div class="mt-10 flex flex-wrap gap-3">
					<span
						class="rounded-full border border-[#d4af37]/30 bg-[#d4af37]/10 px-4 py-2 text-sm font-bold text-[#d4af37]"
					>
						West-Vlaanderen
					</span>

					<span
						class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-neutral-300"
					>
						TP-Link Omada
					</span>

					<span
						class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-neutral-300"
					>
						Outdoor WiFi
					</span>

					<span
						class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-neutral-300"
					>
						PoE
					</span>
				</div>
			</div>

			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div
					class="group relative overflow-hidden rounded-3xl border border-white/10 bg-[#111111]"
				>
					<img
						src="/images/projects/outdoor-wifi/hero.jpeg"
						alt="TP-Link Omada outdoor access point gemonteerd onder een houten overkapping"
						class="h-[460px] w-full object-cover transition duration-700 group-hover:scale-[1.015] sm:h-[600px] lg:h-[720px]"
					/>

					<div
						class="absolute inset-0 bg-gradient-to-t from-black/75 via-transparent to-transparent"
					></div>

					<div
						class="absolute bottom-0 left-0 grid w-full gap-5 p-6 sm:grid-cols-3 sm:p-9"
					>
						<div>
							<p
								class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37]"
							>
								Categorie
							</p>
							<p class="mt-2 font-bold text-white">
								WiFi & Netwerken
							</p>
						</div>

						<div>
							<p
								class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37]"
							>
								Technologie
							</p>
							<p class="mt-2 font-bold text-white">
								TP-Link Omada
							</p>
						</div>

						<div>
							<p
								class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37]"
							>
								Uitvoering
							</p>
							<p class="mt-2 font-bold text-white">
								Plaatsing & configuratie
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- UITDAGING -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid gap-14 lg:grid-cols-[0.8fr_1.2fr]">
					<div>
						<p
							class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
						>
							De uitdaging
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Een betrouwbare WiFi-verbinding buiten, zonder in te boeten aan
							snelheid of stabiliteit.
						</h2>
					</div>

					<div class="space-y-6 text-lg leading-8 text-neutral-400">
						<p>
							De bestaande draadloze verbinding was voornamelijk gericht op de
							binnenruimtes. Op het terras en verder in de tuin was het signaal
							daardoor minder sterk en minder betrouwbaar.
						</p>

						<p>
							De oplossing moest discreet worden geplaatst, geschikt zijn voor
							buitengebruik en naadloos samenwerken met het bestaande netwerk
							in de woning.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- OPLOSSING -->
		<section class="bg-[#0d0d0d] py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid items-center gap-14 lg:grid-cols-2">

					<div>
						<p
							class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
						>
							Onze oplossing
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Strategisch geplaatst voor maximale dekking rond de woning.
						</h2>

						<p class="mt-7 text-lg leading-8 text-neutral-400">
							Het outdoor access point werd onder de houten overkapping
							gemonteerd. Die locatie biedt bescherming, een nette afwerking en
							een gunstige positie om het draadloze signaal over het terras en
							de tuin te verspreiden.
						</p>

						<p class="mt-5 text-lg leading-8 text-neutral-400">
							Het toestel werd via PoE aangesloten en geïntegreerd in de
							TP-Link Omada-omgeving. Zo kan het access point centraal worden
							geconfigureerd en werkt het samen met de andere netwerktoestellen
							als één geheel.
						</p>
					</div>

					<div class="grid gap-5">
						{
							technologies.map((technology, index) => (
								<article
									class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.035] p-7 transition duration-300 hover:-translate-y-1 hover:border-[#d4af37]/55"
								>
									<div
										class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#d4af37]/0 to-transparent transition group-hover:via-[#d4af37]/80"
									></div>

									<div class="flex items-start gap-5">
										<div
											class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-[#d4af37]/30 bg-[#d4af37]/10 font-black text-[#d4af37]"
										>
											{String(index + 1).padStart(2, "0")}
										</div>

										<div>
											<h3 class="text-2xl font-black text-white">
												{technology.name}
											</h3>

											<p class="mt-3 leading-7 text-neutral-400">
												{technology.description}
											</p>
										</div>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- RESULTAAT -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid gap-14 lg:grid-cols-[0.75fr_1.25fr]">
					<div>
						<p
							class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
						>
							Het resultaat
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Een stabiele verbinding van binnen tot buiten.
						</h2>

						<p class="mt-7 text-lg leading-8 text-neutral-400">
							Het terras en de omliggende buitenruimte beschikken nu over een
							sterke en betrouwbare WiFi-verbinding die mooi aansluit op het
							bestaande netwerk in de woning.
						</p>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						{
							benefits.map((benefit) => (
								<div
									class="flex items-start gap-4 rounded-2xl border border-white/10 bg-white/[0.03] p-6"
								>
									<span
										class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[#d4af37]/35 bg-[#d4af37]/10 font-bold text-[#d4af37]"
										aria-hidden="true"
									>
										✓
									</span>

									<p class="leading-7 text-neutral-300">
										{benefit}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- EXTRA PROJECTFOTO -->
		<section class="bg-[#0d0d0d] py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div
					class="relative overflow-hidden rounded-3xl border border-white/10 bg-[#111111]"
				>
					<img
						src="/images/projects/outdoor-wifi/hero.jpeg"
						alt="Detail van de geplaatste outdoor WiFi-oplossing onder de overkapping"
						loading="lazy"
						class="h-[500px] w-full object-cover sm:h-[650px]"
					/>

					<div
						class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/20 to-transparent"
					></div>

					<div
						class="absolute inset-y-0 left-0 flex max-w-xl items-end p-8 sm:p-12"
					>
						<div>
							<p
								class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
							>
								Professionele plaatsing
							</p>

							<h2
								class="mt-5 text-3xl font-black leading-tight text-white sm:text-4xl"
							>
								Discreet gemonteerd en klaar voor jarenlang gebruik.
							</h2>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div
					class="relative overflow-hidden rounded-3xl border border-[#d4af37]/25 bg-[#111111] p-8 sm:p-12 lg:p-16"
				>
					<div
						class="absolute right-0 top-0 h-80 w-80 rounded-full bg-[#d4af37]/10 blur-[110px]"
					></div>

					<div
						class="relative flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between"
					>
						<div class="max-w-3xl">
							<p
								class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
							>
								Ook stabiele WiFi buiten?
							</p>

							<h2
								class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
							>
								Wij zorgen voor de juiste dekking, plaatsing en configuratie.
							</h2>

							<p class="mt-6 text-lg leading-8 text-neutral-400">
								Van terras en tuin tot garage, poolhouse of oprit: we
								bekijken welke netwerkoplossing het beste past bij uw woning.
							</p>
						</div>

						<a
							href="/#contact"
							class="inline-flex min-h-14 shrink-0 items-center justify-center rounded-lg bg-[#d4af37] px-7 font-bold text-black transition hover:-translate-y-1 hover:bg-white"
						>
							Vraag een WiFi-analyse aan
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>