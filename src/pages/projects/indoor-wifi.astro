---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";

const benefits = [
	"Sterke WiFi-dekking boven en beneden",
	"Automatische roaming tussen modem en access point",
	"Geen handmatig wisselen van netwerk",
	"Strategische plaatsing voor maximale dekking",
	"Behoud van de bestaande providerrouter",
	"Eenvoudig uitbreidbaar met extra access points",
];

const features = [
	{
		name: "Bestaande modem behouden",
		description:
			"De router van de internetprovider blijft gewoon actief en vormt samen met het access point één gebruiksvriendelijke WiFi-oplossing.",
	},
	{
		name: "Strategische plaatsing",
		description:
			"Het access point werd boven in een slaapkamer geplaatst, diagonaal tegenover de bestaande modem voor een betere verdeling van het signaal.",
	},
	{
		name: "Automatische roaming",
		description:
			"Smartphones, tablets en laptops schakelen automatisch over naar het sterkste WiFi-punt zonder dat de gebruiker dit merkt.",
	},
];
---

<Layout
	title="Indoor WiFi-installatie | VeYo Smart Solutions"
	description="Strategisch geplaatst indoor access point voor sterke WiFi-dekking boven en beneden, automatische roaming en behoud van de bestaande providerrouter."
>
	<Header />

	<main class="overflow-hidden bg-[#090909] text-white">

		<!-- HERO -->
		<section class="relative overflow-hidden pt-32">
			<div
				class="absolute inset-0 bg-[radial-gradient(circle_at_75%_20%,rgba(212,175,55,0.18),transparent_36%)]"
			></div>

			<div class="relative mx-auto max-w-7xl px-6 pb-16 lg:px-8">
				<a
					href="/#projecten"
					class="inline-flex items-center gap-2 text-sm font-bold text-neutral-400 transition hover:text-[#d4af37]"
				>
					<span aria-hidden="true">←</span>
					Terug naar projecten
				</a>

				<p
					class="mt-12 text-sm font-bold uppercase tracking-[0.25em] text-[#d4af37]"
				>
					WiFi & netwerken
				</p>

				<h1
					class="mt-5 max-w-5xl text-5xl font-black leading-[0.94] tracking-[-0.055em] sm:text-6xl lg:text-8xl"
				>
					Sterke WiFi. 
					<span class="text-[#d4af37]"> Overal in huis.</span>
				</h1>

				<p class="mt-8 max-w-3xl text-lg leading-8 text-neutral-300 sm:text-xl">
					Een strategisch geplaatst access point op de bovenverdieping zorgt
					samen met de bestaande modem voor een sterke en naadloze
					WiFi-verbinding doorheen de volledige woning.
				</p>

				<div class="mt-10 flex flex-wrap gap-3">
					<span
						class="rounded-full border border-[#d4af37]/30 bg-[#d4af37]/10 px-4 py-2 text-sm font-bold text-[#d4af37]"
					>
						West-Vlaanderen
					</span>

					<span
						class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-neutral-300"
					>
						Indoor WiFi
					</span>

					<span
						class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-neutral-300"
					>
						Mesh & roaming
					</span>

					<span
						class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-neutral-300"
					>
						Strategische plaatsing
					</span>
				</div>
			</div>

			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div
					class="group relative overflow-hidden rounded-3xl border border-white/10 bg-[#111111]"
				>
					<img
						src="/images/projects/indoor-wifi/hero.jpeg"
						alt="Indoor access point geplaatst op de bovenverdieping voor volledige WiFi-dekking"
						class="h-[460px] w-full object-cover transition duration-700 group-hover:scale-[1.015] sm:h-[600px] lg:h-[720px]"
					/>

					<div
						class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"
					></div>

					<div
						class="absolute bottom-0 left-0 grid w-full gap-5 p-6 sm:grid-cols-3 sm:p-9"
					>
						<div>
							<p class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37]">
								Categorie
							</p>
							<p class="mt-2 font-bold text-white">
								WiFi & Netwerken
							</p>
						</div>

						<div>
							<p class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37]">
								Opstelling
							</p>
							<p class="mt-2 font-bold text-white">
								Providerrouter + access point
							</p>
						</div>

						<div>
							<p class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37]">
								Uitvoering
							</p>
							<p class="mt-2 font-bold text-white">
								Plaatsing & configuratie
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- UITDAGING -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid gap-14 lg:grid-cols-[0.8fr_1.2fr]">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]">
							De uitdaging
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Volledige dekking creëren zonder de bestaande modem te
							vervangen.
						</h2>
					</div>

					<div class="space-y-6 text-lg leading-8 text-neutral-400">
						<p>
							De standaardrouter van de internetprovider stond beneden en
							bood onvoldoende dekking op de bovenverdieping. In bepaalde
							ruimtes was het signaal zwakker en minder stabiel.
						</p>

						<p>
							De oplossing moest de bestaande modem behouden, maar toch zorgen
							voor een sterke verbinding boven én beneden, zonder dat
							gebruikers handmatig tussen verschillende netwerken moesten
							wisselen.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- OPLOSSING -->
		<section class="bg-[#0d0d0d] py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid items-center gap-14 lg:grid-cols-2">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]">
							Onze oplossing
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Een access point op de juiste plaats maakt het verschil.
						</h2>

						<p class="mt-7 text-lg leading-8 text-neutral-400">
							Het access point werd boven in een slaapkamer geplaatst,
							diagonaal tegenover de bestaande modem beneden. Zo wordt het
							draadloze signaal beter verdeeld over de volledige woning.
						</p>

						<p class="mt-5 text-lg leading-8 text-neutral-400">
							De bestaande providerrouter blijft actief. Het access point
							vult de dekking aan waar het signaal van de modem zwakker wordt,
							zodat beide verdiepingen één sterke en gebruiksvriendelijke
							WiFi-omgeving krijgen.
						</p>
					</div>

					<div class="grid gap-5">
						{
							features.map((feature, index) => (
								<article
									class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.035] p-7 transition duration-300 hover:-translate-y-1 hover:border-[#d4af37]/55"
								>
									<div class="flex items-start gap-5">
										<div
											class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-[#d4af37]/30 bg-[#d4af37]/10 font-black text-[#d4af37]"
										>
											{String(index + 1).padStart(2, "0")}
										</div>

										<div>
											<h3 class="text-2xl font-black text-white">
												{feature.name}
											</h3>

											<p class="mt-3 leading-7 text-neutral-400">
												{feature.description}
											</p>
										</div>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- ROAMING -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid gap-14 lg:grid-cols-[0.75fr_1.25fr]">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]">
							Naadloze roaming
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Uw toestellen kiezen automatisch het sterkste WiFi-punt.
						</h2>
					</div>

					<div class="space-y-6 text-lg leading-8 text-neutral-400">
						<p>
							Een smartphone, tablet of laptop kan automatisch overschakelen
							naar het WiFi-punt met het sterkste signaal terwijl u door de
							woning beweegt.
						</p>

						<p>
							Daardoor hoeft u niet zelf van netwerk te wisselen. De overgang
							gebeurt op de achtergrond, zodat bellen, streamen en surfen zo
							vlot mogelijk blijven verlopen.
						</p>

						<div
							class="rounded-2xl border border-[#d4af37]/25 bg-[#d4af37]/[0.06] p-6"
						>
							<p class="font-bold text-white">
								Geen aparte WiFi-netwerken per verdieping. Wel één eenvoudige
								verbinding doorheen de woning.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- RESULTAAT -->
		<section class="bg-[#0d0d0d] py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid gap-14 lg:grid-cols-[0.75fr_1.25fr]">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]">
							Het resultaat
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Een sterke en stabiele verbinding op beide verdiepingen.
						</h2>

						<p class="mt-7 text-lg leading-8 text-neutral-400">
							De woning beschikt nu over een betere WiFi-verdeling, zonder de
							bestaande modem te vervangen of het dagelijkse gebruik
							ingewikkelder te maken.
						</p>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						{
							benefits.map((benefit) => (
								<div
									class="flex items-start gap-4 rounded-2xl border border-white/10 bg-white/[0.03] p-6"
								>
									<span
										class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[#d4af37]/35 bg-[#d4af37]/10 font-bold text-[#d4af37]"
										aria-hidden="true"
									>
										✓
									</span>

									<p class="leading-7 text-neutral-300">
										{benefit}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- FOTO -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div
					class="relative overflow-hidden rounded-3xl border border-white/10 bg-[#111111]"
				>
					<img
						src="/images/projects/indoor-wifi/hero.jpeg"
						alt="Netjes geplaatst indoor access point op de bovenverdieping"
						loading="lazy"
						class="h-[500px] w-full object-cover sm:h-[650px]"
					/>

					<div
						class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/20 to-transparent"
					></div>

					<div class="absolute inset-y-0 left-0 flex max-w-xl items-end p-8 sm:p-12">
						<div>
							<p class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]">
								Discreet geplaatst
							</p>

							<h2
								class="mt-5 text-3xl font-black leading-tight text-white sm:text-4xl"
							>
								Een nette installatie die opgaat in de ruimte.
							</h2>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="pb-24 sm:pb-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div
					class="relative overflow-hidden rounded-3xl border border-[#d4af37]/25 bg-[#111111] p-8 sm:p-12 lg:p-16"
				>
					<div
						class="absolute right-0 top-0 h-80 w-80 rounded-full bg-[#d4af37]/10 blur-[110px]"
					></div>

					<div
						class="relative flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between"
					>
						<div class="max-w-3xl">
							<p class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]">
								Ook last van zwakke WiFi?
							</p>

							<h2
								class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
							>
								Wij bekijken waar een extra access point het meeste verschil
								maakt.
							</h2>

							<p class="mt-6 text-lg leading-8 text-neutral-400">
								Van één probleemzone tot volledige dekking over meerdere
								verdiepingen: we zoeken een oplossing die past bij uw woning
								en bestaande netwerk.
							</p>
						</div>

						<a
							href="/#contact"
							class="inline-flex min-h-14 shrink-0 items-center justify-center rounded-lg bg-[#d4af37] px-7 font-bold text-black transition hover:-translate-y-1 hover:bg-white"
						>
							Vraag een WiFi-analyse aan
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>