---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";

const solutions = [
	{
		title: "Bekabelde deurbel",
		description:
			"Een vaste voeding zorgt ervoor dat de deurbel niet handmatig opgeladen hoeft te worden. Bestaande bedrading kan waar mogelijk worden hergebruikt of vernieuwd.",
	},
	{
		title: "Deurbel op batterij",
		description:
			"Een praktische oplossing wanneer er geen geschikte bekabeling aanwezig is of wanneer nieuwe kabels trekken niet wenselijk is.",
	},
	{
		title: "Ring of Eufy",
		description:
			"Het gekozen merk en model worden afgestemd op gewenste functies, opslagmogelijkheden, budget en de bestaande slimme toestellen in de woning.",
	},
];

const features = [
	{
		title: "Meldingen op smartphone",
		description:
			"Ontvang een melding wanneer iemand aanbelt of wanneer beweging wordt waargenomen.",
	},
	{
		title: "Livebeeld",
		description:
			"Bekijk via de bijbehorende app wie er aan de deur staat, ook wanneer u niet thuis bent.",
	},
	{
		title: "Tweewegcommunicatie",
		description:
			"Spreek rechtstreeks met een bezoeker via de microfoon en luidspreker van de deurbel.",
	},
	{
		title: "Slimme detectie",
		description:
			"Afhankelijk van het model zijn functies zoals persoons-, bewegings- of pakketdetectie mogelijk.",
	},
	{
		title: "Automatische antwoorden",
		description:
			"Bij geschikte modellen kan een vooraf ingesteld bericht automatisch worden afgespeeld wanneer iemand aanbelt.",
	},
	{
		title: "Opslag naar keuze",
		description:
			"Afhankelijk van het gekozen systeem is lokale opslag mogelijk of kan gebruik worden gemaakt van een abonnementsdienst.",
	},
];

const benefits = [
	"Altijd zien wie er voor de deur staat",
	"Directe meldingen op smartphone of tablet",
	"Bekabeld of volledig draadloos mogelijk",
	"Passende oplossing voor iedere woning",
	"Lokale opslag of cloudopslag mogelijk",
	"Later uitbreidbaar met camera’s en sensoren",
];

const gallery = [
	{
		src: "/images/projects/smart-doorbell/ring-1.jpeg",
		alt: "Ring-videodeurbel netjes gemonteerd tegen een bakstenen gevel",
		className: "sm:col-span-2 lg:row-span-2",
	},
	{
		src: "/images/projects/smart-doorbell/ring-2.jpeg",
		alt: "Ring-videodeurbel geplaatst naast de voordeur",
		className: "",
	},
	{
		src: "/images/projects/smart-doorbell/ring-3.jpeg",
		alt: "Afgewerkte installatie van een Ring slimme deurbel",
		className: "",
	},
	{
		src: "/images/projects/smart-doorbell/eufy-1.jpeg",
		alt: "Eufy-videodeurbel geïnstalleerd aan een woning",
		className: "sm:col-span-2",
	},
];
---

<Layout
	title="Slimme videodeurbellen | VeYo Smart Solutions"
	description="Installatie van slimme Ring- en Eufy-videodeurbellen, bekabeld of op batterij, met smartphone-meldingen, livebeeld en slimme detectiefuncties."
>
	<Header />

	<main class="overflow-hidden bg-[#090909] text-white">

		<!-- HERO -->
		<section class="relative overflow-hidden pt-32">
			<div
				class="absolute inset-0 bg-[radial-gradient(circle_at_75%_20%,rgba(212,175,55,0.18),transparent_36%)]"
			></div>

			<div class="relative mx-auto max-w-7xl px-6 pb-16 lg:px-8">
				<a
					href="/#projecten"
					class="inline-flex items-center gap-2 text-sm font-bold text-neutral-400 transition hover:text-[#d4af37]"
				>
					<span aria-hidden="true">←</span>
					Terug naar projecten
				</a>

				<p
					class="mt-12 text-sm font-bold uppercase tracking-[0.25em] text-[#d4af37]"
				>
					Camera’s & beveiliging
				</p>

				<h1
					class="mt-5 max-w-5xl text-5xl font-black leading-[0.94] tracking-[-0.055em] sm:text-6xl lg:text-8xl"
				>
					Zien wie aanbelt.
					<span class="text-[#d4af37]">Waar u ook bent.</span>
				</h1>

				<p class="mt-8 max-w-3xl text-lg leading-8 text-neutral-300 sm:text-xl">
					Een slimme videodeurbel geeft onmiddellijk zicht en controle aan de
					voordeur. Van een bekabelde Ring-installatie tot een draadloze
					Eufy-oplossing: iedere woning vraagt om een passende aanpak.
				</p>

				<div class="mt-10 flex flex-wrap gap-3">
					<span
						class="rounded-full border border-[#d4af37]/30 bg-[#d4af37]/10 px-4 py-2 text-sm font-bold text-[#d4af37]"
					>
						West-Vlaanderen
					</span>

					<span
						class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-neutral-300"
					>
						Ring
					</span>

					<span
						class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-neutral-300"
					>
						Eufy
					</span>

					<span
						class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-neutral-300"
					>
						Bekabeld of batterij
					</span>
				</div>
			</div>

			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div
					class="group relative overflow-hidden rounded-3xl border border-white/10 bg-[#111111]"
				>
					<img
						src="/images/projects/smart-doorbell/ring-1.jpeg"
						alt="Ring slimme videodeurbel geïnstalleerd tegen een bakstenen gevel"
						class="h-[500px] w-full object-cover transition duration-700 group-hover:scale-[1.015] sm:h-[620px] lg:h-[760px]"
					/>

					<div
						class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/10 to-transparent"
					></div>

					<div
						class="absolute bottom-0 left-0 grid w-full gap-5 p-6 sm:grid-cols-3 sm:p-9"
					>
						<div>
							<p
								class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37]"
							>
								Categorie
							</p>
							<p class="mt-2 font-bold text-white">
								Slimme beveiliging
							</p>
						</div>

						<div>
							<p
								class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37]"
							>
								Merken
							</p>
							<p class="mt-2 font-bold text-white">
								Ring & Eufy
							</p>
						</div>

						<div>
							<p
								class="text-xs font-bold uppercase tracking-[0.2em] text-[#d4af37]"
							>
								Uitvoering
							</p>
							<p class="mt-2 font-bold text-white">
								Plaatsing & configuratie
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- UITDAGING -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid gap-14 lg:grid-cols-[0.8fr_1.2fr]">
					<div>
						<p
							class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
						>
							De uitdaging
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Een klassieke deurbel vervangen door meer zicht, comfort en
							controle.
						</h2>
					</div>

					<div class="space-y-6 text-lg leading-8 text-neutral-400">
						<p>
							Een traditionele deurbel laat alleen horen dat er iemand voor de
							deur staat. Wie er aanbelt, wat er gebeurt wanneer niemand thuis
							is en of een pakket werd geleverd, blijft onbekend.
						</p>

						<p>
							De nieuwe oplossing moest eenvoudig te bedienen zijn via een
							smartphone en passen bij de technische mogelijkheden van de
							woning. Daarbij werd rekening gehouden met beschikbare
							bekabeling, gewenste functies en opslagmogelijkheden.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- KEUZEMOGELIJKHEDEN -->
		<section class="bg-[#0d0d0d] py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="max-w-3xl">
					<p
						class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
					>
						Een oplossing op maat
					</p>

					<h2
						class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl lg:text-6xl"
					>
						Niet iedere woning heeft
						<span class="text-[#d4af37]"> dezelfde deurbel nodig.</span>
					</h2>

					<p class="mt-7 text-lg leading-8 text-neutral-400">
						We bekijken eerst de bestaande situatie en kiezen vervolgens een
						oplossing die aansluit bij de woning, gewenste functies en het
						budget.
					</p>
				</div>

				<div class="mt-14 grid gap-5 lg:grid-cols-3">
					{
						solutions.map((solution, index) => (
							<article
								class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.035] p-7 transition duration-300 hover:-translate-y-1 hover:border-[#d4af37]/55"
							>
								<div
									class="flex h-12 w-12 items-center justify-center rounded-xl border border-[#d4af37]/30 bg-[#d4af37]/10 font-black text-[#d4af37]"
								>
									{String(index + 1).padStart(2, "0")}
								</div>

								<h3 class="mt-6 text-2xl font-black text-white">
									{solution.title}
								</h3>

								<p class="mt-3 leading-7 text-neutral-400">
									{solution.description}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<!-- OPLOSSING -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid items-center gap-14 lg:grid-cols-2">
					<div class="grid grid-cols-2 gap-4">
						<div
							class="col-span-2 overflow-hidden rounded-3xl border border-white/10"
						>
							<img
								src="/images/projects/smart-doorbell/ring-2.jpeg"
								alt="Ring-videodeurbel netjes geplaatst naast een voordeur"
								class="h-[420px] w-full object-cover"
							/>
						</div>

						<div
							class="overflow-hidden rounded-2xl border border-white/10"
						>
							<img
								src="/images/projects/smart-doorbell/ring-3.jpeg"
								alt="Detail van een afgewerkte Ring-deurbelinstallatie"
								class="h-[300px] w-full object-cover"
							/>
						</div>

						<div
							class="overflow-hidden rounded-2xl border border-white/10"
						>
							<img
								src="/images/projects/smart-doorbell/eufy-1.jpeg"
								alt="Geïnstalleerde Eufy slimme videodeurbel"
								class="h-[300px] w-full object-cover"
							/>
						</div>
					</div>

					<div>
						<p
							class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
						>
							Onze aanpak
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Van bestaande deurbel naar een volledig ingestelde slimme
							oplossing.
						</h2>

						<p class="mt-7 text-lg leading-8 text-neutral-400">
							De oude deurbel wordt verwijderd en de nieuwe videodeurbel wordt
							netjes op de meest geschikte plaats gemonteerd. Wanneer
							bestaande bedrading bruikbaar is, kan die worden hergebruikt.
							Indien nodig kan de bekabeling worden aangepast of vernieuwd.
						</p>

						<p class="mt-5 text-lg leading-8 text-neutral-400">
							Wanneer bekabeling niet mogelijk of niet aanwezig is, kan een
							model op batterij een geschikt alternatief zijn. Na plaatsing
							wordt de deurbel verbonden met het netwerk en wordt de app
							ingesteld en getest.
						</p>

						<p class="mt-5 text-lg leading-8 text-neutral-400">
							De beschikbare functies verschillen per merk en model. Daarom
							wordt vooraf bekeken welke oplossing het best aansluit bij de
							wensen van de gebruiker.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- FUNCTIES -->
		<section class="bg-[#0d0d0d] py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid gap-14 lg:grid-cols-[0.7fr_1.3fr]">
					<div>
						<p
							class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
						>
							Slimme functies
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Meer dan alleen zien wie er aanbelt.
						</h2>

						<p class="mt-7 text-lg leading-8 text-neutral-400">
							Afhankelijk van het gekozen toestel zijn verschillende slimme
							functies beschikbaar. Zo wordt de deurbel een volwaardig
							onderdeel van de beveiliging rond de woning.
						</p>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						{
							features.map((feature) => (
								<article
									class="rounded-2xl border border-white/10 bg-white/[0.03] p-6"
								>
									<div
										class="flex h-9 w-9 items-center justify-center rounded-full border border-[#d4af37]/35 bg-[#d4af37]/10 font-bold text-[#d4af37]"
										aria-hidden="true"
									>
										✓
									</div>

									<h3 class="mt-5 text-xl font-black text-white">
										{feature.title}
									</h3>

									<p class="mt-3 leading-7 text-neutral-400">
										{feature.description}
									</p>
								</article>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- RING EN EUFY -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid gap-6 lg:grid-cols-2">
					<article
						class="relative overflow-hidden rounded-3xl border border-white/10 bg-[#111111] p-8 sm:p-10"
					>
						<div
							class="absolute right-0 top-0 h-64 w-64 rounded-full bg-[#d4af37]/10 blur-[100px]"
						></div>

						<div class="relative">
							<p
								class="text-sm font-bold uppercase tracking-[0.22em] text-[#d4af37]"
							>
								Ring
							</p>

							<h2 class="mt-5 text-3xl font-black sm:text-4xl">
								Een uitgebreid ecosysteem met verschillende modellen.
							</h2>

							<p class="mt-6 leading-8 text-neutral-400">
								Ring biedt verschillende bekabelde en draadloze
								videodeurbellen en kan gecombineerd worden met andere
								Ring-camera’s en beveiligingsproducten.
							</p>

							<p class="mt-5 leading-8 text-neutral-400">
								Beschikbare opnames en geavanceerde functies kunnen
								afhankelijk zijn van het gekozen toestel en abonnement.
							</p>
						</div>
					</article>

					<article
						class="relative overflow-hidden rounded-3xl border border-white/10 bg-[#111111] p-8 sm:p-10"
					>
						<div
							class="absolute right-0 top-0 h-64 w-64 rounded-full bg-[#d4af37]/10 blur-[100px]"
						></div>

						<div class="relative">
							<p
								class="text-sm font-bold uppercase tracking-[0.22em] text-[#d4af37]"
							>
								Eufy
							</p>

							<h2 class="mt-5 text-3xl font-black sm:text-4xl">
								Slimme beveiliging met mogelijkheden voor lokale opslag.
							</h2>

							<p class="mt-6 leading-8 text-neutral-400">
								Eufy biedt zowel bekabelde als draadloze modellen en kan,
								afhankelijk van de gekozen configuratie, gebruikmaken van
								lokale opslag via een compatibele HomeBase.
							</p>

							<p class="mt-5 leading-8 text-neutral-400">
								Ook hier verschillen slimme detectiefuncties en
								opslagmogelijkheden per model en systeem.
							</p>
						</div>
					</article>
				</div>
			</div>
		</section>

		<!-- RESULTAAT -->
		<section class="bg-[#0d0d0d] py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="grid gap-14 lg:grid-cols-[0.75fr_1.25fr]">
					<div>
						<p
							class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
						>
							Het resultaat
						</p>

						<h2
							class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
						>
							Meer controle aan de voordeur, thuis én onderweg.
						</h2>

						<p class="mt-7 text-lg leading-8 text-neutral-400">
							De klassieke deurbel maakt plaats voor een gebruiksvriendelijke
							oplossing waarmee bezoekers zichtbaar zijn en communicatie via
							de smartphone mogelijk wordt.
						</p>
					</div>

					<div class="grid gap-5 sm:grid-cols-2">
						{
							benefits.map((benefit) => (
								<div
									class="flex items-start gap-4 rounded-2xl border border-white/10 bg-white/[0.03] p-6"
								>
									<span
										class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[#d4af37]/35 bg-[#d4af37]/10 font-bold text-[#d4af37]"
										aria-hidden="true"
									>
										✓
									</span>

									<p class="leading-7 text-neutral-300">
										{benefit}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- GALERIJ -->
		<section class="py-24 sm:py-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div class="max-w-3xl">
					<p
						class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
					>
						Realisaties
					</p>

					<h2
						class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
					>
						Ring en Eufy,
						<span class="text-[#d4af37]"> netjes geïnstalleerd.</span>
					</h2>
				</div>

				<div
					class="mt-14 grid auto-rows-[320px] gap-5 sm:grid-cols-2 lg:grid-cols-3"
				>
					{
						gallery.map((image) => (
							<figure
								class:list={[
									"group relative overflow-hidden rounded-2xl border border-white/10 bg-[#111111]",
									image.className,
								]}
							>
								<img
									src={image.src}
									alt={image.alt}
									loading="lazy"
									class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
								/>

								<div
									class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 transition duration-300 group-hover:opacity-100"
								></div>
							</figure>
						))
					}
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="pb-24 sm:pb-32">
			<div class="mx-auto max-w-7xl px-6 lg:px-8">
				<div
					class="relative overflow-hidden rounded-3xl border border-[#d4af37]/25 bg-[#111111] p-8 sm:p-12 lg:p-16"
				>
					<div
						class="absolute right-0 top-0 h-80 w-80 rounded-full bg-[#d4af37]/10 blur-[110px]"
					></div>

					<div
						class="relative flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between"
					>
						<div class="max-w-3xl">
							<p
								class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
							>
								Ook uw klassieke deurbel vervangen?
							</p>

							<h2
								class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] sm:text-5xl"
							>
								Wij zoeken de slimme deurbel die past bij uw woning en wensen.
							</h2>

							<p class="mt-6 text-lg leading-8 text-neutral-400">
								Bekabeld of op batterij, met lokale opslag of cloudfuncties:
								we adviseren, plaatsen en configureren de volledige oplossing.
							</p>
						</div>

						<a
							href="/#contact"
							class="inline-flex min-h-14 shrink-0 items-center justify-center rounded-lg bg-[#d4af37] px-7 font-bold text-black transition hover:-translate-y-1 hover:bg-white"
						>
							Bespreek uw slimme deurbel
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>