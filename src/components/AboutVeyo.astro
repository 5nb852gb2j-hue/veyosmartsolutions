---
const highlights = [
	"Persoonlijk advies en rechtstreeks contact",
	"Installatie, configuratie en duidelijke uitleg",
	"Oplossingen voor woningen en kleine bedrijven",
	"Actief in West- en Oost-Vlaanderen",
];
---

<section
	id="over-veyo"
	class="relative overflow-hidden bg-[#0d0d0d] py-24 sm:py-32"
>
	<div
		class="absolute left-1/2 top-0 h-px w-[80%] -translate-x-1/2 bg-gradient-to-r from-transparent via-[#d4af37]/40 to-transparent"
	></div>

	<div
		class="absolute -left-40 top-1/2 h-[500px] w-[500px] -translate-y-1/2 rounded-full bg-[#d4af37]/5 blur-[150px]"
	></div>

	<div class="relative mx-auto max-w-7xl px-6 lg:px-8">
		<div class="grid items-center gap-14 lg:grid-cols-2 lg:gap-20">

			<!-- Fotoblok -->
			<div class="relative">
				<div
					class="relative min-h-[560px] overflow-hidden rounded-3xl border border-white/10 bg-[radial-gradient(circle_at_50%_25%,rgba(212,175,55,0.22),transparent_32%),linear-gradient(145deg,#1a1a1a,#080808)]"
				>
					<div
						class="absolute inset-0 opacity-[0.06] [background-image:linear-gradient(rgba(255,255,255,0.35)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.35)_1px,transparent_1px)] [background-size:45px_45px]"
					></div>

					<div
						class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black via-black/75 to-transparent p-8 pt-32"
					>
						<p
							class="text-sm font-bold uppercase tracking-[0.22em] text-[#d4af37]"
						>
							Het gezicht achter VeYo
						</p>

						<h3 class="mt-3 text-3xl font-black text-white">
							Yordi Verheecke
						</h3>

						<p class="mt-2 text-neutral-400">
							Oprichter van VeYo Smart Solutions
						</p>
					</div>

					<div
						class="absolute left-8 top-8 rounded-full border border-[#d4af37]/35 bg-black/50 px-4 py-2 text-sm font-bold text-[#d4af37] backdrop-blur-md"
					>
						Smart home • Netwerken • Technologie
					</div>
				</div>

				<div
					class="absolute -bottom-6 -right-3 max-w-[260px] rounded-2xl border border-[#d4af37]/30 bg-[#121212] p-5 shadow-2xl sm:right-8"
				>
					<p class="text-sm leading-6 text-neutral-400">
						“Technologie moet uw leven eenvoudiger maken, niet ingewikkelder.”
					</p>
				</div>
			</div>

			<!-- Tekstblok -->
			<div>
				<p
					class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
				>
					Over VeYo
				</p>

				<h2
					class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] text-white sm:text-5xl lg:text-6xl"
				>
					Persoonlijke service met een passie voor
					<span class="text-[#d4af37]">slimme technologie.</span>
				</h2>

				<p class="mt-7 text-lg leading-8 text-neutral-400">
					VeYo Smart Solutions helpt particulieren en kleine bedrijven om
					technologie slimmer, veiliger en gebruiksvriendelijker in te zetten.
					Van een betere WiFi-verbinding tot een volledig geïntegreerde smart
					home-installatie.
				</p>

				<p class="mt-5 text-lg leading-8 text-neutral-400">
					Elke opdracht start met luisteren naar uw wensen. Daarna zoeken we
					naar een betrouwbare oplossing die aansluit bij uw woning, bestaande
					installatie en budget.
				</p>

				<ul class="mt-8 grid gap-4 sm:grid-cols-2">
					{
						highlights.map((highlight) => (
							<li class="flex items-start gap-3">
								<span
									class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-[#d4af37]/40 bg-[#d4af37]/10 text-sm font-bold text-[#d4af37]"
									aria-hidden="true"
								>
									✓
								</span>

								<span class="leading-7 text-neutral-300">
									{highlight}
								</span>
							</li>
						))
					}
				</ul>

				<div class="mt-10 flex flex-col gap-4 sm:flex-row">
					<a
						href="#contact"
						class="inline-flex min-h-14 items-center justify-center rounded-lg bg-[#d4af37] px-7 font-bold text-black transition duration-300 hover:-translate-y-1 hover:bg-white"
					>
						Maak kennis met VeYo
					</a>

					<a
						href="#projecten"
						class="inline-flex min-h-14 items-center justify-center rounded-lg border border-white/15 px-7 font-bold text-white transition duration-300 hover:-translate-y-1 hover:border-[#d4af37] hover:text-[#d4af37]"
					>
						Bekijk onze realisaties
					</a>
				</div>
			</div>
		</div>
	</div>
</section>