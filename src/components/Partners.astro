---
const brands = [
	{
		name: "Homey",
		category: "Smart home-platform",
	},
	{
		name: "TP-Link Omada",
		category: "WiFi & netwerken",
	},
	{
		name: "Eufy",
		category: "Beveiliging & smart home",
	},
	{
		name: "Ajax Systems",
		category: "Alarmsystemen",
	},
	{
		name: "Sonos",
		category: "Multiroom audio",
	},
	{
		name: "Shelly",
		category: "Slimme schakelingen",
	},
	{
		name: "Ring",
		category: "Deurbellen & camera’s",
	},
	{
		name: "Nuki",
		category: "Slimme deursloten",
	},
	{
		name: "HomeWizard",
		category: "Energiebeheer",
	},
];
---

<section class="relative overflow-hidden bg-[#090909] py-24 sm:py-32">
	<div
		class="absolute left-1/2 top-0 h-px w-[80%] -translate-x-1/2 bg-gradient-to-r from-transparent via-[#d4af37]/40 to-transparent"
	></div>

	<div
		class="absolute left-1/2 top-1/2 h-[460px] w-[760px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#d4af37]/5 blur-[150px]"
	></div>

	<div class="relative mx-auto max-w-7xl px-6 lg:px-8">
		<div class="mx-auto max-w-3xl text-center">
			<p
				class="text-sm font-bold uppercase tracking-[0.24em] text-[#d4af37]"
			>
				Betrouwbare technologie
			</p>

			<h2
				class="mt-5 text-4xl font-black leading-tight tracking-[-0.045em] text-white sm:text-5xl lg:text-6xl"
			>
				Merken die passen bij
				<span class="text-[#d4af37]">uw project.</span>
			</h2>

			<p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-neutral-400">
				We selecteren betrouwbare producten en platformen op basis van uw
				wensen, bestaande installatie en budget. Niet één merk staat centraal,
				maar de oplossing die het beste bij u past.
			</p>
		</div>

		<div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{
				brands.map((brand) => (
					<article
						class="group flex min-h-32 items-center justify-between gap-5 rounded-2xl border border-white/10 bg-white/[0.03] px-6 py-5 transition duration-300 hover:-translate-y-1 hover:border-[#d4af37]/55 hover:bg-[#d4af37]/[0.055]"
					>
						<div>
							<h3
								class="text-xl font-black tracking-[-0.025em] text-neutral-300 transition duration-300 group-hover:text-[#d4af37]"
							>
								{brand.name}
							</h3>

							<p class="mt-1 text-sm text-neutral-500">
								{brand.category}
							</p>
						</div>

						<div
							class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/10 text-lg text-neutral-600 transition duration-300 group-hover:border-[#d4af37]/50 group-hover:text-[#d4af37]"
							aria-hidden="true"
						>
							+
						</div>
					</article>
				))
			}
		</div>

		<div
			class="mt-10 flex flex-col items-start justify-between gap-5 rounded-2xl border border-white/10 bg-white/[0.025] p-7 sm:flex-row sm:items-center"
		>
			<div>
				<h3 class="text-xl font-bold text-white">
					Heeft u al slimme toestellen in huis?
				</h3>

				<p class="mt-2 text-neutral-400">
					We onderzoeken graag of uw bestaande producten geïntegreerd en
					uitgebreid kunnen worden.
				</p>
			</div>

			<a
				href="#contact"
				class="inline-flex min-h-13 shrink-0 items-center justify-center rounded-lg border border-[#d4af37] px-6 font-bold text-white transition duration-300 hover:-translate-y-1 hover:bg-[#d4af37] hover:text-black"
			>
				Laat uw installatie bekijken
			</a>
		</div>

		<p class="mt-6 text-center text-xs leading-5 text-neutral-600">
			De vermelde merknamen zijn eigendom van hun respectieve
			merkhouders. Productkeuze is afhankelijk van de technische vereisten
			van ieder project.
		</p>
	</div>
</section>