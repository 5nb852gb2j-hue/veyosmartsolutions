---
const navigation = [
	{ label: "Diensten", href: "/#diensten" },
	{ label: "Projecten", href: "/#projecten" },
	{ label: "Merken", href: "/#merken" },
	{ label: "FAQ", href: "/#faq" },
	{ label: "Over VeYo", href: "/#over-veyo" },
	{ label: "Contact", href: "/#contact" },
];
---

<header
	class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-[#080808]/85 backdrop-blur-xl"
>
	<div class="mx-auto max-w-7xl px-6 lg:px-8">
		<div class="flex h-20 items-center justify-between gap-6">

			<!-- Logo -->
			<a
				href="/"
				class="group inline-flex shrink-0 items-center gap-2"
				aria-label="VeYo Smart Solutions homepage"
			>
				<span
					class="text-2xl font-black tracking-[-0.04em] text-[#d4af37] transition group-hover:text-white"
				>
					VeYo
				</span>

				<span
					class="hidden text-lg font-bold tracking-[-0.025em] text-white sm:inline"
				>
					Smart Solutions
				</span>
			</a>

			<!-- Desktopnavigatie -->
			<nav
				class="hidden items-center gap-7 lg:flex"
				aria-label="Hoofdnavigatie"
			>
				{
					navigation.map((item) => (
						<a
							href={item.href}
							class="group relative py-7 text-sm font-bold text-neutral-300 transition hover:text-white"
						>
							{item.label}

							<span
								class="absolute inset-x-0 bottom-5 h-px origin-left scale-x-0 bg-[#d4af37] transition duration-300 group-hover:scale-x-100"
							></span>
						</a>
					))
				}
			</nav>

			<!-- Desktop CTA -->
			<a
				href="/#contact"
				class="hidden min-h-12 shrink-0 items-center justify-center rounded-lg bg-[#d4af37] px-6 text-sm font-black text-black transition duration-300 hover:-translate-y-0.5 hover:bg-white lg:inline-flex"
			>
				Offerte aanvragen
			</a>

			<!-- Mobiel menu -->
			<details class="group relative lg:hidden">
				<summary
					class="flex h-12 w-12 cursor-pointer list-none items-center justify-center rounded-lg border border-white/10 bg-white/[0.04] text-white transition hover:border-[#d4af37]/50 hover:text-[#d4af37]"
					aria-label="Open navigatiemenu"
				>
					<span class="relative block h-5 w-6">
						<span
							class="absolute left-0 top-0 h-0.5 w-6 bg-current transition duration-300 group-open:top-[9px] group-open:rotate-45"
						></span>

						<span
							class="absolute left-0 top-[9px] h-0.5 w-6 bg-current transition duration-300 group-open:opacity-0"
						></span>

						<span
							class="absolute bottom-0 left-0 h-0.5 w-6 bg-current transition duration-300 group-open:bottom-[9px] group-open:-rotate-45"
						></span>
					</span>
				</summary>

				<div
					class="absolute right-0 top-16 w-[min(88vw,340px)] overflow-hidden rounded-2xl border border-white/10 bg-[#101010]/95 p-3 shadow-2xl backdrop-blur-xl"
				>
					<nav class="flex flex-col" aria-label="Mobiele navigatie">
						{
							navigation.map((item) => (
								<a
									href={item.href}
									class="rounded-xl px-4 py-3.5 font-bold text-neutral-300 transition hover:bg-white/[0.05] hover:text-[#d4af37]"
								>
									{item.label}
								</a>
							))
						}

						<a
							href="/#contact"
							class="mt-3 inline-flex min-h-12 items-center justify-center rounded-lg bg-[#d4af37] px-5 font-black text-black transition hover:bg-white"
						>
							Offerte aanvragen
						</a>

						<a
							href="https://wa.me/32456536037?text=Hallo%20Yordi%2C%20ik%20heb%20interesse%20in%20een%20slimme%20oplossing%20van%20VeYo%20Smart%20Solutions."
							target="_blank"
							rel="noreferrer"
							class="mt-3 inline-flex min-h-12 items-center justify-center rounded-lg border border-[#25D366]/40 px-5 font-bold text-[#25D366] transition hover:bg-[#25D366] hover:text-black"
						>
							WhatsApp
						</a>
					</nav>
				</div>
			</details>
		</div>
	</div>
</header>