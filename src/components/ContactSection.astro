---
const voordelen = [
  "Gratis eerste advies",
  "Vrijblijvende offerte",
  "Persoonlijke installatie",
  "Actief in West- & Oost-Vlaanderen"
];
---

<section id="contact" class="relative bg-[#0d0d0d] py-28">

    <div class="absolute inset-0 bg-[radial-gradient(circle_at_75%_20%,rgba(212,175,55,0.12),transparent_40%)]"></div>

    <div class="relative mx-auto max-w-7xl px-6 lg:px-8">

        <div class="grid gap-16 lg:grid-cols-2 items-center">

            <div>

                <p class="uppercase tracking-[0.3em] text-[#d4af37] font-bold text-sm">
                    CONTACT
                </p>

                <h2 class="mt-5 text-5xl font-black leading-tight text-white">
                    Klaar om uw woning
                    <span class="text-[#d4af37]">
                        slimmer
                    </span>
                    te maken?
                </h2>

                <p class="mt-8 text-lg leading-8 text-neutral-400">

                    Of het nu gaat om betere WiFi, slimme verlichting,
                    beveiliging of een volledige smart home...
                    we luisteren eerst naar uw wensen en werken daarna
                    een oplossing uit die écht bij u past.

                </p>

                <div class="mt-10 grid gap-5">

                    {
                        voordelen.map(item => (

                            <div class="flex items-center gap-4">

                                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#d4af37]/10 border border-[#d4af37]/30 text-[#d4af37]">

                                    ✓

                                </div>

                                <span class="text-neutral-300">

                                    {item}

                                </span>

                            </div>

                        ))
                    }

                </div>

            </div>

            <div
                class="rounded-3xl border border-white/10 bg-[#141414] p-8 shadow-2xl">

                <h3 class="text-2xl font-bold text-white">

                    Vraag vrijblijvend een offerte aan

                </h3>

                <p class="mt-3 text-neutral-400">

                    Binnenkort kan u hier rechtstreeks een aanvraag indienen.

                </p>

                <div class="mt-8 space-y-5">

                    <input
                        placeholder="Naam"
                        class="w-full rounded-xl border border-white/10 bg-black/30 px-5 py-4 text-white outline-none focus:border-[#d4af37]"
                    />

                    <input
                        placeholder="E-mailadres"
                        class="w-full rounded-xl border border-white/10 bg-black/30 px-5 py-4 text-white outline-none focus:border-[#d4af37]"
                    />

                    <input
                        placeholder="Telefoon"
                        class="w-full rounded-xl border border-white/10 bg-black/30 px-5 py-4 text-white outline-none focus:border-[#d4af37]"
                    />

                    <textarea
                        rows="5"
                        placeholder="Vertel kort over uw project..."
                        class="w-full rounded-xl border border-white/10 bg-black/30 px-5 py-4 text-white outline-none focus:border-[#d4af37]"
                    ></textarea>

                    <button
                        class="w-full rounded-xl bg-[#d4af37] py-4 font-bold text-black transition hover:scale-[1.02]">

                        Offerte aanvragen

                    </button>

                </div>

            </div>

        </div>

    </div>

</section>