---
const phoneNumber = "32456536037";
const message =
	"Hallo Yordi, ik heb interesse in een slimme oplossing van VeYo Smart Solutions en had graag wat meer informatie.";

const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
---

<a
	href={whatsappUrl}
	target="_blank"
	rel="noreferrer"
	aria-label="Neem contact op via WhatsApp"
	class="group fixed bottom-8 right-8 z-50 flex h-16 w-16 items-center justify-center rounded-full bg-[#25D366] text-white shadow-2xl shadow-black/40 transition duration-300 hover:-translate-y-1 hover:scale-105 focus:outline-none focus:ring-4 focus:ring-[#25D366]/30"
>
	<svg
		viewBox="0 0 32 32"
		aria-hidden="true"
		class="h-8 w-8 fill-current"
	>
		<path
			d="M19.11 17.39c-.29-.15-1.72-.85-1.99-.95-.27-.1-.46-.15-.66.15-.19.29-.75.95-.92 1.14-.17.19-.34.22-.63.07-.29-.15-1.22-.45-2.33-1.44-.86-.77-1.44-1.72-1.61-2.01-.17-.29-.02-.45.13-.59.13-.13.29-.34.44-.51.15-.17.19-.29.29-.49.1-.19.05-.37-.02-.51-.07-.15-.66-1.58-.9-2.16-.24-.57-.48-.49-.66-.5h-.56c-.19 0-.51.07-.78.37-.27.29-1.02 1-1.02 2.43 0 1.44 1.05 2.82 1.19 3.02.15.19 2.06 3.14 4.99 4.4.7.3 1.24.48 1.67.62.7.22 1.33.19 1.83.12.56-.08 1.72-.7 1.96-1.37.24-.68.24-1.26.17-1.38-.07-.12-.27-.19-.56-.34Z"
		/>
		<path
			d="M16.03 3.2c-6.99 0-12.67 5.56-12.67 12.4 0 2.19.58 4.33 1.69 6.21L3.25 28.8l7.3-1.87a12.82 12.82 0 0 0 5.47 1.22h.01c6.98 0 12.66-5.56 12.66-12.4 0-3.31-1.3-6.42-3.67-8.76A12.78 12.78 0 0 0 16.03 3.2Zm0 22.85h-.01a10.68 10.68 0 0 1-5.07-1.29l-.36-.19-4.33 1.11 1.15-4.13-.21-.37a10.2 10.2 0 0 1-1.59-5.48c0-5.69 4.72-10.32 10.52-10.32 2.81 0 5.45 1.07 7.43 3.03a10.13 10.13 0 0 1 3.08 7.27c0 5.69-4.72 10.37-10.61 10.37Z"
		/>
	</svg>

	<span
		class="pointer-events-none absolute right-20 hidden whitespace-nowrap rounded-lg border border-white/10 bg-[#111111] px-4 py-2 text-sm font-bold text-white shadow-xl opacity-0 transition duration-300 group-hover:translate-x-0 group-hover:opacity-100 sm:block sm:translate-x-2"
	>
		Stuur ons een WhatsApp
	</span>
</a>